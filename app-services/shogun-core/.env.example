# ── Database ──────────────────────────────────────────────────────────────────
# Docker Desktop: platform-postgres (container name on platform_net)
# Lab (3-node):   192.168.71.221 (dbnode-01 bare metal Postgres)
DB_HOST=platform-postgres
DB_PORT=5432
DB_NAME=shogun_v1
DB_USER=shogun_app
DB_PASSWORD=REPLACE_ME

# ── Valkey ────────────────────────────────────────────────────────────────────
# Docker Desktop: platform-valkey (container name on platform_net)
# Lab (3-node):   valkey.platform.ibbytech.com
VALKEY_HOST=platform-valkey
VALKEY_PORT=6379
VALKEY_PASSWORD=REPLACE_ME

# ── Platform services ─────────────────────────────────────────────────────────
# Docker Desktop: container names on platform_net (http, no TLS)
# Lab (3-node):   FQDNs via Traefik (https)
LLM_GATEWAY_URL=http://platform-llm-gateway:8080
TELEGRAM_GATEWAY_URL=http://platform-telegram-gateway:3001
TELEGRAM_SEND_SECRET=REPLACE_ME
TELEGRAM_BOT_TOKEN=REPLACE_ME
TAVILY_GATEWAY_URL=http://platform-tavily:8084
SCRAPER_GATEWAY_URL=http://platform-scraper-api:8083

# ── App ───────────────────────────────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8082
LOG_LEVEL=info
