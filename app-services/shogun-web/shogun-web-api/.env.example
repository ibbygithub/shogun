# shogun-web-api — environment template
# Copy to .env and fill in real values.
# Never commit .env to git.

# ── Auth ─────────────────────────────────────────────────────────────────────
# true  = laptop/Docker Desktop mode — no auth enforcement (no Cloudflare Access)
# false = production mode — Cloudflare Access handles auth at the edge
SHOGUN_BYPASS_AUTH=true

# ── Database ──────────────────────────────────────────────────────────────────
# Docker Desktop: postgresql://shogun_app:PASSWORD@platform-postgres/shogun_v1
# Lab (3-node):   postgresql://shogun_app:PASSWORD@192.168.71.221/shogun_v1
DATABASE_URL=postgresql://shogun_app:PASSWORD@platform-postgres/shogun_v1

# ── Valkey ────────────────────────────────────────────────────────────────────
# Docker Desktop: redis://:PASSWORD@platform-valkey:6379
# Lab (3-node):   redis://:PASSWORD@valkey.platform.ibbytech.com:6379
VALKEY_URL=redis://:PASSWORD@platform-valkey:6379

# ── Platform services ─────────────────────────────────────────────────────────
# Docker Desktop: container names on platform_net
# Lab (3-node):   FQDNs via Traefik (http://llm.platform.ibbytech.com)
LLM_GATEWAY_URL=http://platform-llm-gateway:8080

# Tavily gateway — port 8084 on Docker Desktop, FQDN on lab
# Used by ambient router for sakura, transit, events searches
TAVILY_GATEWAY_URL=http://platform-tavily:8084

# ── Next.js proxy target ──────────────────────────────────────────────────────
# SERVER-SIDE value used by next.config.js rewrites() — not sent to the browser.
# Browser calls /api/* (relative); Next.js server proxies to this URL.
# Docker Desktop: http://shogun-web-api:8090 (container name, server resolves it)
# Lab (3-node):   http://shogun-api.ibbytech.com (FQDN via Traefik)
NEXT_PUBLIC_API_URL=http://shogun-web-api:8090
