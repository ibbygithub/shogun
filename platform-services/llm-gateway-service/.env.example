# OpenAI
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# Google Gemini (Generative Language API)
GOOGLE_API_KEY=
GOOGLE_BASE_URL=https://generativelanguage.googleapis.com

# Google Maps Platform (Places API, etc.)
# NOTE: This is the Cloud Console API key (Maps/Places). It can be the same value as GOOGLE_API_KEY,
# but keeping it separate avoids confusion because it comes from a different console/product family.
GOOGLE_MAPS_API_KEY=
GOOGLE_PLACES_BASE_URL=https://places.googleapis.com

# Defaults
DEFAULT_EMBED_PROVIDER=openai
DEFAULT_EMBED_MODEL=text-embedding-3-small

DEFAULT_CHAT_PROVIDER=google
DEFAULT_CHAT_MODEL=gemini-2.0-flash
